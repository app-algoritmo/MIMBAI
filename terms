    #cookie-banner.show{transform:translateY(0)}
    .cb-top{max-width:1120px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap}
    .cb-left{display:flex;align-items:center;gap:10px}
    .cb-title{font-size:13px;font-weight:700;letter-spacing:.12em;color:var(--amber);text-transform:uppercase}
    .cb-desc{font-size:12px;color:#8899bb;line-height:1.55;max-width:420px;flex:1;min-width:200px}
    .cb-desc a{color:var(--amber);text-decoration:underline}
    .cb-btns{display:flex;gap:8px;align-items:center}
    .cb-btn-accept{background:var(--amber);color:#fff;border:none;padding:8px 20px;border-radius:6px;font-size:12px;font-weight:700;text-transform:uppercase;cursor:pointer}
    .cb-btn-save{background:transparent;color:var(--amber);border:1.5px solid var(--amber);padding:7px 18px;border-radius:6px;font-size:12px;font-weight:600;text-transform:uppercase;cursor:pointer}
    .cb-btn-reject{background:transparent;color:#6b7280;border:none;padding:7px 10px;font-size:12px;cursor:pointer}
    .cb-bottom{max-width:1120px;margin:10px auto 0;display:flex;gap:24px;align-items:center;padding-top:10px;border-top:1px solid rgba(255,255,255,.06);flex-wrap:wrap}
    .cb-toggle-item{display:flex;align-items:center;gap:8px}
    .cb-toggle-label{font-size:12px;color:#8899bb;font-weight:500}
    .cb-toggle{position:relative;display:inline-block;width:36px;height:20px}
    .cb-toggle input{display:none}
    .cb-track{position:absolute;inset:0;border-radius:20px;background:#374151;cursor:pointer;transition:background .2s}
    .cb-track::after{content:'';position:absolute;top:3px;left:3px;width:14px;height:14px;border-radius:50%;background:#fff;transition:transform .2s}
    .cb-toggle input:checked+.cb-track{background:var(--amber)}
    .cb-toggle input:checked+.cb-track::after{transform:translateX(16px)}
    .cb-toggle input:disabled+.cb-track{opacity:.6;cursor:not-allowed}
    @media(max-width:600px){.wrap{padding:32px 16px 60px}}
  </style>
